# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# MongoDB connection string
# Free cluster: https://cloud.mongodb.com → New Project → Free tier (M0)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/image-resizer?retryWrites=true&w=majority

# Session encryption secret — must be at least 32 random characters
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-a-random-string-of-at-least-32-characters
